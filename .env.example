KICK_USERNAME=your_kick_username_here
LOG_LEVEL=WARNING
TTS_ENABLED=true
# Comma-separated badge types that can use !tts (e.g. vip,moderator,broadcaster). Use "none" to allow everyone.
TTS_BADGES=vip
# When true, the Whisplay RGB LED stays green while pysher is connected.
CONNECTED_LED_ENABLED=false
